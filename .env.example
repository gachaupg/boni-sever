MONGODB_URL=mongodb+srv://...
JWT_SECRET=your-secret-key-change-in-production
PORT=3001

# Product images (pick one):
# A) Cloudinary — recommended on Render (URLs persist). Copy from Cloudinary dashboard → API Keys → "API environment variable".
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET instead.

# B) Local disk only if Cloudinary is NOT set — use a persistent disk mount in production.
# UPLOADS_DIR=/var/render/data/uploads
